<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <servlet>
        <servlet-name>SmartCampusApp</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <init-param>
            <!-- Scan all flat packages where resources, mappers, and filters live.
                 These match the package declarations in the actual .java files. -->
            <param-name>jersey.config.server.provider.packages</param-name>
            <param-value>resource,exception,filter,config</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>SmartCampusApp</servlet-name>
        <!-- Maps to /api/v1/* so all endpoints sit under /api/v1 -->
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>
